# cheiron-ct-agent — environment.
# The ONLY secret in the system is the LLM provider key, read by app/llm/adapter.py alone
# (ARCHITECTURE_SPEC §A(e)): never passed to tools, never logged, redacted on error.

# --- LLM provider (provider-agnostic adapter — pick one; unset ⇒ the offline StubAdapter) ---
# LLM_PROVIDER selects the adapter. With no key set, the service still runs on a deterministic
# StubAdapter (no network, a fixed plan) so it never hard-crashes; set a provider + key for the
# real agentic layer. Model IDs below are verified-live defaults (2026-07-16); override if needed.
#
# LLM_PROVIDER=openai              # openai | anthropic | openrouter | stub
#
# OpenAI (the reference run path):
# OPENAI_API_KEY=sk-...            # or any OpenAI-compatible key
# LLM_MODEL_PLANNER=gpt-5.4        # strong model for the planner (classify → fill)
# LLM_MODEL_REVIEWER=gpt-5.4-mini  # cheap model for the two reviewers
#
# Anthropic (the second concrete adapter — proves the adapter is provider-agnostic):
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL_PLANNER=claude-opus-4-8
# LLM_MODEL_REVIEWER=claude-haiku-4-5
#
# OpenRouter / a local OpenAI-compatible server (reuses the OpenAI adapter via a base_url):
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...     # (or OPENAI_API_KEY + LLM_BASE_URL)
# LLM_BASE_URL=https://openrouter.ai/api/v1

# --- ClinicalTrials.gov API (no auth, no key — public registry) ---
# CTGOV_BASE_URL=https://clinicaltrials.gov/api/v2   # base-pinned; never user-overridable in prod
# CTGOV_RATE_LIMIT_RPS=3          # politeness limiter (~3 req/s; [UNVERIFIED] per API brief)

# --- service ---
# LOG_LEVEL=info                    # info | debug | warning; structured events only, key+raw-query redacted (§A(i))

# --- Phase-5 guards / caps / cache (all OPTIONAL — sane defaults live in app/config.py) ---
# Runtime-harness backstops (deploy-time config, never agent-tunable — §B.4):
# MAX_REACT_ITERATIONS=8            # plan re-entries (forward-compat headroom under the v1 planner)
# MAX_TOOL_CALLS=12                 # total tool fan-out
# MAX_GRAPH_STEPS=40                # hard node-visit backstop
# WALL_CLOCK_SYNC_SECONDS=60        # POST /visualize deadline
# WALL_CLOCK_SSE_SECONDS=90         # /visualize/stream deadline
# Paging + response-size caps:
# PAGE_BUDGET_PAGES=20              # 20 × 1000 = 20,000-trial page budget
# TOO_LARGE_THRESHOLD=20000         # > this → status:"too_large" (exact countTotal, refuse the chart)
# TOP_N_CATEGORIES=50              # ranked-bar top-N + "Other"
# NETWORK_MAX_NODES=60             # network top-N nodes by degree
# CITATION_SAMPLE_K=20             # ≤K cited nctIds per datum
# Input caps:
# MAX_QUERY_CHARS=500              # query length cap
# MAX_STRUCTURED_FIELD_CHARS=200   # drug/condition/sponsor/country cap (G-41b)
# MAX_COMPARE_ENTITIES=5           # compare-arm cap (first-N + dropped note, E-21)
# Response cache (non-authoritative; §3.10):
# CACHE_ENABLED=true               # bypass switch (set false to always recompute)
# CACHE_TTL_SECONDS=300            # short TTL, keyed on the normalized plan
# CACHE_MAX_ENTRIES=128            # LRU bound
